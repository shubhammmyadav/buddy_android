<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        The actual Material3 theme is assembled entirely in Compose (BuddyTheme).
        This XML theme is only needed by the Activity window before Compose draws its first frame.
    -->
    <style name="Theme.Buddy" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
